menu "Motor Controller"

    config TWAI_TX_GPIO
        int "CAN TX GPIO number"
        default 38
        help
            GPIO connected to the CAN transceiver TX pin (e.g. TJA1051T).

    config TWAI_RX_GPIO
        int "CAN RX GPIO number"
        default 39
        help
            GPIO connected to the CAN transceiver RX pin.

    config CAN_ID_Z_A
        hex "Z-axis motor A CAN ID"
        default 0x01

    config CAN_ID_Z_B
        hex "Z-axis motor B CAN ID"
        default 0x02

    config CAN_ID_X
        hex "X-axis motor CAN ID"
        default 0x03

    config JOG_SPEED_RPM
        int "Jog speed (RPM)"
        default 300
        range 10 3000

    config JOG_ACCEL
        int "Jog acceleration (0-255)"
        default 50
        range 0 255

    config MOTOR_Z_INVERT
        bool "Invert Z-axis direction"
        default n
        help
            Swap CW/CCW for Z motors when physical mounting reverses direction.

    config MOTOR_X_INVERT
        bool "Invert X-axis direction"
        default n

endmenu
